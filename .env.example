# OracleIQ API Environment Variables
# Copy this file to .env and fill in the values

# Required for all Clive APIs
PORT=8080
NODE_ENV=production
SERVICE_NAME=oracleiq

# Redis (optional - Railway sets this automatically when you add Redis plugin)
REDIS_URL=

# OracleIQ specific - Required for AI analysis
ANTHROPIC_API_KEY=

# Optional API keys for enrichment
SHODAN_API_KEY=
NVD_API_KEY=
HIBP_API_KEY=

# Sync intervals (optional)
KALSHI_SYNC_INTERVAL_MS=300000      # 5 minutes
POLYMARKET_SYNC_INTERVAL_MS=300000  # 5 minutes
METACULUS_SYNC_INTERVAL_MS=1800000  # 30 minutes
MANIFOLD_SYNC_INTERVAL_MS=1800000   # 30 minutes

# Platform API endpoints
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
METACULUS_API_BASE=https://www.metaculus.com/api2
MANIFOLD_API_BASE=https://api.manifold.markets/v0

# Cache TTL
MARKET_DETAIL_CACHE_TTL_SECONDS=30
ANALYSIS_CACHE_TTL_HOURS=2
CATEGORY_DASHBOARD_CACHE_TTL_MINUTES=10
TRENDING_CACHE_TTL_MINUTES=2

# Features
ENABLE_WEBSOCKET=true
ENABLE_EMBEDS=true
EMBED_BASE_URL=https://embed.oracleiq.dev