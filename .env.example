# OracleIQ API — copy to .env and fill in values

PORT=3000
NODE_ENV=production

# Firebase (required)
FIREBASE_PROJECT_ID=your-project-id
# Paste the full JSON of your service account key as a single line:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Anthropic (required for AI analysis)
ANTHROPIC_API_KEY=

# Sync intervals (optional)
KALSHI_SYNC_INTERVAL_MS=300000
POLYMARKET_SYNC_INTERVAL_MS=300000
METACULUS_SYNC_INTERVAL_MS=1800000
MANIFOLD_SYNC_INTERVAL_MS=1800000

# Platform API endpoints
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
METACULUS_API_BASE=https://www.metaculus.com/api2
MANIFOLD_API_BASE=https://api.manifold.markets/v0

# Cache TTL
MARKET_DETAIL_CACHE_TTL_SECONDS=30
ANALYSIS_CACHE_TTL_HOURS=2
CATEGORY_DASHBOARD_CACHE_TTL_MINUTES=10
TRENDING_CACHE_TTL_MINUTES=2

# Features
DEMO_SEED_ON_STARTUP=true
ENABLE_WEBSOCKET=true
ENABLE_EMBEDS=true
EMBED_BASE_URL=https://embed.oracleiq.dev
